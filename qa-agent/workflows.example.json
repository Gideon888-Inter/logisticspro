[
  {
    "name": "Public home page loads",
    "requiresAuth": false,
    "steps": [
      { "action": "goto", "path": "/" },
      { "action": "expectTitleOrUrl", "contains": "" },
      { "action": "expectVisible", "selector": "body" }
    ]
  },
  {
    "name": "Login page is reachable",
    "requiresAuth": false,
    "steps": [
      { "action": "goto", "path": "/login" },
      { "action": "expectVisibleAny", "selectors": ["input[type='email']", "input[name='email']", "text=/email/i"] }
    ]
  },
  {
    "name": "Authenticated dashboard smoke test",
    "requiresAuth": true,
    "steps": [
      { "action": "login" },
      { "action": "goto", "path": "/dashboard" },
      { "action": "expectVisible", "selector": "body" }
    ]
  }
]
